{
  "name": "medspa-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @medspa/api --filter @medspa/dashboard dev",
    "dev:api": "pnpm --filter @medspa/api dev",
    "dev:dashboard": "pnpm --filter @medspa/dashboard dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "eval": "pnpm --filter @medspa/eval run eval",
    "db:migrate": "pnpm --filter @medspa/api db:migrate",
    "db:seed": "tsx scripts/seed-tenant.ts",
    "demo": "tsx scripts/demo-conversation.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
