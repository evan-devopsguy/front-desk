# ============================================================================
# Production env for the Mac Mini deployment (Cooper Family Garage Doors).
# Copy to .env.production on the Mac Mini and fill every value below.
#
# Anything tagged "ROTATE BEFORE DEPLOY" must be a fresh, non-default value
# generated specifically for this deployment.
#
# Used by docker-compose.prod.yml. The deploy workflow does NOT modify this
# file — populate it once on the Mac Mini and keep it out of git.
# ============================================================================

# ---------- API ----------
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# ---------- Postgres (consumed by docker-compose.prod.yml) ----------
# REQUIRED — ROTATE BEFORE DEPLOY. Used both as the postgres superuser
# password (on first init) and embedded into DATABASE_URL.
POSTGRES_PASSWORD=

# DATABASE_URL is set by docker-compose.prod.yml from POSTGRES_PASSWORD —
# do not override here. The container resolves "postgres" via the compose
# network. Listed for documentation only.
# DATABASE_URL=postgres://medspa:${POSTGRES_PASSWORD}@postgres:5432/medspa

# ---------- AWS / Bedrock ----------
# IAM user with bedrock:InvokeModel permission only. No volume mount needed.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_REASONING_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_CLASSIFIER_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ---------- Twilio ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# REQUIRED. Set to the Tailscale Funnel URL for this Mac Mini, e.g.
# https://mac-mini.tail1234.ts.net (no trailing slash). Twilio's signature
# validation depends on this matching the URL byte-for-byte.
PUBLIC_BASE_URL=https://mac-mini.tail1234.ts.net

# ---------- Secrets Manager ----------
SECRETS_PREFIX=/medspa/prod
